{
  "_doc": "Curated mapping of flavor vocabulary term → minimum ingredient signature required for a brand to honestly deliver that flavor in a dish (not just gesture toward it). Used by compute_pantry_fit.py to decide which flavors each brand can deliver vs which are gaps. match_terms are substring-checked against pantry items (parentheticals stripped). min_matches = how many distinct match_terms must hit.",

  "adobo sauce":     {"match_terms": ["adobo", "chipotle"], "min_matches": 1, "notes": "Chipotle in adobo or any adobo-marinated SKU counts."},
  "al pastor":       {"match_terms": ["al pastor", "achiote"], "min_matches": 1, "notes": "Either the named protein or achiote spice base."},
  "bao bun":         {"match_terms": ["bao", "steamed bun"], "min_matches": 1, "notes": "Specific format — no substitution."},
  "birria":          {"match_terms": ["birria", "consommé", "guajillo", "ancho"], "min_matches": 2, "notes": "Needs dried chiles + braise concept. Guajillo + ancho together qualify even without 'birria' label."},
  "bulgogi":         {"match_terms": ["bulgogi", "korean bbq", "kbbq"], "min_matches": 1, "notes": "KBBQ sauce or labeled bulgogi protein."},
  "burrata":         {"match_terms": ["burrata"], "min_matches": 1, "notes": "Specific cheese — no real substitute."},
  "calabrian chili": {"match_terms": ["calabrian"], "min_matches": 1, "notes": "Specific chile, distinct flavor profile."},
  "cauliflower":     {"match_terms": ["cauliflower"], "min_matches": 1, "notes": "Literal ingredient required."},
  "crispy chickpeas":{"match_terms": ["chickpea", "crispy", "falafel"], "min_matches": 2, "notes": "Crispy + chickpea, or falafel as a deliverable form."},
  "curry goat":      {"match_terms": ["goat", "curry"], "min_matches": 2, "notes": "Both needed — neither alone delivers the dish."},
  "dashi":           {"match_terms": ["dashi", "kombu", "bonito"], "min_matches": 1, "notes": "Japanese stock; specific umami base."},
  "elote":           {"match_terms": ["corn", "cotija", "crema", "tajin", "tajín"], "min_matches": 2, "notes": "Corn + at least one Mexican-corn-street finish."},
  "farro":           {"match_terms": ["farro"], "min_matches": 1, "notes": "Specific grain."},
  "freekeh":         {"match_terms": ["freekeh"], "min_matches": 1, "notes": "Specific grain."},
  "furikake":        {"match_terms": ["furikake", "nori sesame"], "min_matches": 1, "notes": "Japanese seasoning blend."},
  "gochujang":       {"match_terms": ["gochujang", "korean chili"], "min_matches": 1, "notes": "Korean chile paste."},
  "harissa":         {"match_terms": ["harissa"], "min_matches": 1, "notes": "Named paste/dressing/protein."},
  "jerk":            {"match_terms": ["jerk", "allspice", "scotch bonnet", "thyme"], "min_matches": 2, "notes": "Jerk seasoning OR 2 of (allspice, scotch bonnet, thyme). NOTE: thyme bundled inside a protein prep does not count as a standalone SKU — only explicit thyme topping/seasoning qualifies."},
  "karaage":         {"match_terms": ["karaage", "japanese fried chicken"], "min_matches": 1, "notes": "Specific prep style."},
  "kimchi":          {"match_terms": ["kimchi"], "min_matches": 1, "notes": "Includes apple kimchi or apple kimchi sauce."},
  "lentils":         {"match_terms": ["lentil"], "min_matches": 1, "notes": "Plural or singular."},
  "miso":            {"match_terms": ["miso"], "min_matches": 1, "notes": "Any miso-named SKU — dressing, glaze, or sauce."},
  "mole":            {"match_terms": ["mole"], "min_matches": 1, "notes": "Named sauce — no substitute."},
  "nduja":           {"match_terms": ["nduja", "'nduja"], "min_matches": 1, "notes": "Spreadable Calabrian sausage."},
  "oxtail":          {"match_terms": ["oxtail"], "min_matches": 1, "notes": "Specific protein."},
  "pesto":           {"match_terms": ["pesto"], "min_matches": 1, "notes": "Sauce/dressing/vinaigrette named 'pesto'."},
  "plantain":        {"match_terms": ["plantain"], "min_matches": 1, "notes": "Specific ingredient."},
  "scotch bonnet":   {"match_terms": ["scotch bonnet"], "min_matches": 1, "notes": "Specific chile; can also satisfy jerk."},
  "shakshuka":       {"match_terms": ["shakshuka", "soft-cooked egg", "egg + tomato"], "min_matches": 1, "notes": "Named dish OR soft-cooked egg as topping qualifies."},
  "sumac":           {"match_terms": ["sumac"], "min_matches": 1, "notes": "Spice or sumac slaw / topping."},
  "tahini":          {"match_terms": ["tahini"], "min_matches": 1, "notes": "Dressing or sauce."},
  "tonkotsu":        {"match_terms": ["tonkotsu", "pork bone broth"], "min_matches": 1, "notes": "Specific ramen broth concept."},
  "truffle":         {"match_terms": ["truffle"], "min_matches": 1, "notes": "Truffle oil / salt / shavings — no substitute. Mushroom + parmesan is NOT truffle."},
  "yuzu":            {"match_terms": ["yuzu"], "min_matches": 1, "notes": "Specific citrus."},
  "za'atar":         {"match_terms": ["za'atar", "zaatar"], "min_matches": 1, "notes": "Specific spice blend."},
  "cotija":          {"match_terms": ["cotija"], "min_matches": 1, "notes": "Specific cheese."},
  "crema":           {"match_terms": ["crema", "mexican crema"], "min_matches": 1, "notes": "Specific cultured-cream."},
  "allspice":        {"match_terms": ["allspice"], "min_matches": 1, "notes": "Specific spice; also satisfies jerk partial."},
  "banchan":         {"match_terms": ["banchan"], "min_matches": 1, "notes": "Korean side dishes."},
  "galbi":           {"match_terms": ["galbi", "kalbi", "korean short rib"], "min_matches": 1, "notes": "Specific Korean grilled beef rib."},
  "japchae":         {"match_terms": ["japchae", "glass noodle"], "min_matches": 1, "notes": "Specific Korean glass-noodle dish."},
  "shawarma":        {"match_terms": ["shawarma"], "min_matches": 1, "notes": "Specific preparation."},
  "labneh":          {"match_terms": ["labneh"], "min_matches": 1, "notes": "Strained-yogurt cheese — tzatziki does NOT qualify (different ratio + texture)."},
  "halloumi":        {"match_terms": ["halloumi"], "min_matches": 1, "notes": "Specific cheese — grills."},
  "guajillo":        {"match_terms": ["guajillo"], "min_matches": 1, "notes": "Specific dried chile; partial match for birria."},
  "ancho":           {"match_terms": ["ancho"], "min_matches": 1, "notes": "Specific dried chile; partial match for birria."},
  "tofu":            {"match_terms": ["tofu", "sofritas"], "min_matches": 1, "notes": "Tofu in any form including Chipotle's sofritas."},
  "kabocha":         {"match_terms": ["kabocha", "japanese pumpkin"], "min_matches": 1, "notes": "Specific squash."},
  "ube":             {"match_terms": ["ube", "purple yam"], "min_matches": 1, "notes": "Specific ingredient."},
  "matcha":          {"match_terms": ["matcha"], "min_matches": 1, "notes": "Specific green tea powder."}
}
