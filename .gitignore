data/cava_byo/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Build outputs we keep
# dist/SUBMISSION.pdf, dist/VIDEO_SCRIPT.pdf, dist/slides/PRESENTATION.pdf are committed.
# Regenerable screenshots are not.
dist/slides/shots/
