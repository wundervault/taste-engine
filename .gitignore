# Secrets — never commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local state
*.log
/tmp/
